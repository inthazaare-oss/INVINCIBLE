# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# WhatsApp-enabled Twilio sender, in Twilio's "whatsapp:+1..." format.
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Exact public URL configured as this number's "When a message comes in" webhook
# in the Twilio console. Must match byte-for-byte (scheme/host/path) -- Twilio
# signs requests against this literal URL.
WEBHOOK_URL=https://your-domain.example.com/webhook/whatsapp

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-5
MAX_TURNS=8
MAX_BUDGET_USD=0.50
# JSON list of extra tools to enable beyond plain chat, e.g. ["WebSearch"].
# Leave unset/empty for a pure conversational bot (recommended default).
# Bash/BashOutput/KillShell are hard-blocked regardless of this setting.
# ALLOWED_TOOLS=[]

# --- Storage (mount as a persistent volume in production) ---
DATABASE_PATH=data/whatsapp_bot.sqlite3
SANDBOX_ROOT=data/sandboxes

# --- Rate limiting (per process) ---
RATE_LIMIT_MAX_MESSAGES=10
RATE_LIMIT_WINDOW_SECONDS=60

# --- Access control ---
# JSON list of allowed WhatsApp numbers, e.g. ["whatsapp:+15551234567"].
# Leave unset/empty to serve anyone who messages the Twilio number.
# ALLOWED_PHONE_NUMBERS=[]

LOG_LEVEL=INFO
